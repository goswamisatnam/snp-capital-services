# ─────────────────────────────────────────
# S&P Capital Services – Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────

# Anthropic Claude — AI Finance Assistant (server-side only, never prefix with NEXT_PUBLIC_)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Site URL (used for SEO canonical, OG tags)
NEXT_PUBLIC_SITE_URL=https://snpcapitalservices.com

# Google Analytics 4 Measurement ID (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Market Data API (optional – for live prices)
# Recommended: Alpha Vantage (free tier), Polygon.io, or Finnhub
MARKET_API_KEY=your_api_key_here
MARKET_API_PROVIDER=alphavantage   # alphavantage | polygon | finnhub

# Email Newsletter (optional)
# Recommended: Mailchimp, ConvertKit, or Resend
NEWSLETTER_API_KEY=your_newsletter_key
NEWSLETTER_LIST_ID=your_list_id

# Contact Form (optional)
# Recommended: Resend.com for transactional email
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL=contact@snpcapitalservices.com
